# ── LLM ──────────────────────────────────────────────────────
GOOGLE_API_KEY="AIzaSyAN_XeLNUJzi-bcQ5bFcR0VxKDyEF-at9Y"

# ── Models ───────────────────────────────────────────────────
# Vision / OCR model
OCR_MODEL=gemini-2.5-flash

# Grading model (structured output)
GRADING_MODEL=gemini-2.5-pro

# Embedding model for plagiarism detection
EMBEDDING_MODEL=text-embedding-004

# ── Pipeline thresholds ───────────────────────────────────────
# OCR confidence below this → flag for priority TA review
OCR_CONFIDENCE_THRESHOLD=0.80

# Cosine similarity above this → flag as potential plagiarism
PLAGIARISM_THRESHOLD=0.92

# Hours before auto-approve kicks in (0 = disabled)
AUTO_APPROVE_HOURS=48

# ── Storage ───────────────────────────────────────────────────
# "local" | "s3" | "gcs"
STORAGE_BACKEND=local

# Local storage root (used when STORAGE_BACKEND=local)
LOCAL_STORAGE_PATH=./scratch

# S3 config (only needed when STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=gradeops-exams

# GCS config (only needed when STORAGE_BACKEND=gcs)
# GCS_BUCKET=gradeops-exams

# ── Development ───────────────────────────────────────────────
# Set to "true" to skip real LLM calls (deterministic mocks)
MOCK_LLM=false

# ── Server ────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:3000
