# ─────────────────────────────────────────────────────────────────────────────
# GradeOps Pipeline — Environment Variables
# Copy this file to .env and fill in your API keys.
#
#   cp .env.example .env
#
# Lines starting with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Gemini API key (used for OCR + embeddings).
# Free tier: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Groq API key (used for text grading — fast, generous free tier).
# Free tier: https://console.groq.com/keys
GROQ_API_KEY=


# ── Model Selection ───────────────────────────────────────────────────────────
# Vision OCR model (must support image input).
OCR_MODEL=gemini-2.0-flash

# Text grading model and provider.
# Supported providers: groq | google
GRADING_PROVIDER=groq
GRADING_MODEL=llama3-70b-8192

# Embedding model for plagiarism detection (Google only).
EMBEDDING_MODEL=models/text-embedding-004


# ── Quality Thresholds ────────────────────────────────────────────────────────
# OCR confidence below this value triggers a "priority review" flag for the TA.
OCR_CONFIDENCE_THRESHOLD=0.80

# Cosine similarity above this value between two student transcripts flags them
# as potentially plagiarised (1.0 = identical, 0.95 is a very conservative default).
PLAGIARISM_THRESHOLD=0.95

# Hours after which unreviewed AI grades are auto-approved (0 = disabled).
AUTO_APPROVE_HOURS=48


# ── Storage ───────────────────────────────────────────────────────────────────
# Where page images and gradebook files are stored.
# Options: local | s3 | gcs
STORAGE_BACKEND=local

# Path for local storage (relative to the pipeline/ directory).
LOCAL_STORAGE_PATH=./scratch

# AWS S3 bucket name (only used when STORAGE_BACKEND=s3).
S3_BUCKET=

# Google Cloud Storage bucket name (only used when STORAGE_BACKEND=gcs).
GCS_BUCKET=


# ── Concurrency & Resilience ──────────────────────────────────────────────────
# Maximum simultaneous LLM API calls per agent.
# Lower this if you hit rate-limit errors (429).
LLM_CONCURRENCY=4

# Maximum retry attempts on transient API errors (429, 503).
LLM_MAX_RETRIES=2


# ── Development ───────────────────────────────────────────────────────────────
# Set to true to skip all LLM calls and return deterministic mock responses.
# Useful for local UI development without API keys.
MOCK_LLM=false


# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000
